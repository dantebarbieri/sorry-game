# Root-level env for `docker compose up`. Copy to `.env` and adjust as needed.

# Host port the nginx frontend binds to. Inside the container it's always 80.
SORRY_FRONTEND_PORT=8080

# Build-time: bake a specific backend origin into the frontend bundle.
# Leave empty for same-origin deploys — the bundle will use
# window.location.origin and nginx proxies /api/* to the backend service.
VITE_SERVER_URL=

# Runtime CORS for sorry-server. Empty disables CORS entirely (same-origin).
# Use "*" to allow anything (dev only). Use a specific origin in production
# if the frontend is served from a different host than the backend.
SORRY_CORS_ORIGIN=

RUST_LOG=sorry_server=info,tower_http=info
