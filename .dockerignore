# Local git state + editor + OS noise
.git/
.gitignore
.claude/
.vscode/
.idea/
.zed/
.helix/
*.swp
*.swo
.DS_Store
Thumbs.db

# Rust build output — always rebuild inside the image
target/

# WASM + SvelteKit build output — regenerated by the multi-stage build
frontend/src/lib/pkg/
frontend/pkg/
frontend/static/pkg/
frontend/build/
frontend/.svelte-kit/
frontend/.vite/
frontend/dist/
frontend/node_modules/
node_modules/

# Env / secrets never belong in the image
.env
.env.*
!.env.example

# Local-only reference material
inspo/
*.log
coverage/
tmp/
