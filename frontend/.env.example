# Frontend build-time config. Copy to `.env` for local dev and adjust as needed.
# None of these are secrets — they are baked into the client bundle.

# Override the base URL for sorry-server REST + WebSocket requests.
# Leave unset to use the smart default:
#   - `pnpm dev`           → http://localhost:8080 (pair with `cargo run` server)
#   - production (browser) → window.location.origin (nginx same-origin proxy)
# Set this only if the backend lives on a different host from the frontend.
# VITE_SERVER_URL=http://localhost:8080
